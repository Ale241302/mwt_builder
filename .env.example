# ----- Postgres del builder -----
DB_NAME=mwt_builder_db
DB_USER=postgres
DB_PASSWORD=cambia-esto-en-produccion

# ----- Django -----
SECRET_KEY=genera-una-clave-larga-y-aleatoria-aqui
DEBUG=False

# Hosts permitidos (coma-separados, sin espacios). El reverse proxy mwt-nginx
# llega como Host: builder.muito.work. "django" se deja para llamadas internas
# entre containers. 187.77.218.102 y localhost ayudan en debug puntual.
ALLOWED_HOSTS=builder.muito.work,django,187.77.218.102,localhost

# Origenes confiables para CSRF (HTTPS público).
CSRF_TRUSTED_ORIGINS=https://builder.muito.work

# ----- Frontend (build-time) -----
# El Dockerfile del frontend hardcodea esta URL en el bundle de Vite.
# Si la cambias, hay que rebuild: `docker compose build nginx`.
VITE_API_URL=https://builder.muito.work
